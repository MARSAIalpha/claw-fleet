{
  "$comment": "小龙虾舰队统一配置 — 在 VPS 上编辑此文件，通过 Syncthing 自动同步到所有电脑",

  "fleet": {
    "name": "Simon's Claw Fleet",
    "version": "1.0.0",
    "openclaw_version": "latest",
    "default_model": "deepseek/deepseek-chat",
    "telegram": {
      "group_id": "-100XXXXXXXXXX",
      "topics": {
        "指挥部": "TOPIC_ID_HERE",
        "编剧组": "TOPIC_ID_HERE",
        "美术组": "TOPIC_ID_HERE",
        "视频组": "TOPIC_ID_HERE",
        "发布组": "TOPIC_ID_HERE",
        "数据组": "TOPIC_ID_HERE",
        "日志":   "TOPIC_ID_HERE"
      }
    }
  },

  "agents": [
    {
      "id": "orchestrator",
      "name": "指挥虾",
      "machine": "rog",
      "model": "anthropic/claude-sonnet-4-6",
      "soul": "shared/souls/orchestrator.md",
      "skills": ["task-dispatch", "status-report", "fleet-monitor"],
      "bot_token_env": "CLAW_BOT_TOKEN_ORCH",
      "topic": "指挥部",
      "heartbeat_interval": 300
    },
    {
      "id": "writer",
      "name": "编剧虾",
      "machine": "macmini",
      "model": "deepseek/deepseek-chat",
      "soul": "shared/souls/writer.md",
      "skills": ["screenplay", "copywriting", "novel-parser"],
      "bot_token_env": "CLAW_BOT_TOKEN_WRITER",
      "topic": "编剧组",
      "heartbeat_interval": 300
    },
    {
      "id": "artist",
      "name": "美术虾",
      "machine": "4090",
      "model": "deepseek/deepseek-chat",
      "soul": "shared/souls/artist.md",
      "skills": ["sd-prompt", "midjourney", "storyboard"],
      "bot_token_env": "CLAW_BOT_TOKEN_ARTIST",
      "topic": "美术组",
      "heartbeat_interval": 300
    },
    {
      "id": "video",
      "name": "视频虾",
      "machine": "macbook",
      "model": "deepseek/deepseek-chat",
      "soul": "shared/souls/video.md",
      "skills": ["ffmpeg-edit", "tts-gen", "subtitle-gen"],
      "bot_token_env": "CLAW_BOT_TOKEN_VIDEO",
      "topic": "视频组",
      "heartbeat_interval": 300
    },
    {
      "id": "publisher",
      "name": "发布虾",
      "machine": "p4",
      "model": "deepseek/deepseek-chat",
      "soul": "shared/souls/publisher.md",
      "skills": ["multi-platform", "analytics", "seo-optimizer"],
      "bot_token_env": "CLAW_BOT_TOKEN_PUB",
      "topic": "发布组",
      "heartbeat_interval": 300
    },
    {
      "id": "databot",
      "name": "数据虾",
      "machine": "macmini2",
      "model": "deepseek/deepseek-chat",
      "soul": "shared/souls/databot.md",
      "skills": ["health-data", "timeline-api", "report-gen"],
      "bot_token_env": "CLAW_BOT_TOKEN_DATA",
      "topic": "数据组",
      "heartbeat_interval": 300
    }
  ],

